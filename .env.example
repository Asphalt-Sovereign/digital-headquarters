# Used for canonical URLs, sitemap entries, and social metadata.
# The GitHub Pages workflow sets this automatically.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional explicit static-export base path. Leave empty for root deployment.
# Standard project-site GitHub Actions builds infer /digital-headquarters.
NEXT_PUBLIC_BASE_PATH=

# Optional footer build identifier. GitHub Actions uses the short commit SHA.
NEXT_PUBLIC_BUILD_ID=local
